APP_ENV=production
TZ=UTC

DATA_DIR=/data
DB_PATH=/data/airgrabber.db
PROFILES_PATH=/app/profiles.yaml
SNAPSHOT_DIR=/data/snapshots
ARCHIVE_DIR=/data/archive
TELEGRAM_SPOOL_DIR=/data/spool/telegram

DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8080

FAKE_SDR=false
AGGRESSIVE_DETECT=false
AUTHORIZED_AUDIO_MODE=false

SCAN_TIMEOUT_SEC=20
SCAN_LOOP_PAUSE_SEC=1.0
SERVICE_HEARTBEAT_TTL_SEC=90
RETENTION_HOURS=24

TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_POLL_TIMEOUT_SEC=25
TELEGRAM_RETRY_BASE_SEC=15
TELEGRAM_RETRY_MAX_SEC=300
TELEGRAM_SEND_SNAPSHOTS=true

AUDIO_CLIP_MAX_SEC=60
AUDIO_PRE_ROLL_SEC=5
AUDIO_POST_ROLL_SEC=10

SELFTEST_AUDIO_ENABLED=true
SELFTEST_AUDIO_FREQ_HZ=1000
SELFTEST_AUDIO_SEC=8
WB_DEPLOY_HOST=
WB_DEPLOY_USER=root
WB_DEPLOY_PATH=/opt/wb-sdr-air-grabberer

